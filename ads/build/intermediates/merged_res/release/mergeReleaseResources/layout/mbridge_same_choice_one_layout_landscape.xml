<?xml version="1.0" encoding="utf-8"?>
<com.mbridge.msdk.dycreator.baseview.cusview.MBridgeFramLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mbridge_choice_frl"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="75dp"
        android:gravity="center"
        android:orientation="horizontal">

        <RelativeLayout
            android:id="@+id/mbridge_top_item_rl"
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:layout_weight="1">

            <com.mbridge.msdk.dycreator.baseview.cusview.MBRotationView
                android:id="@+id/mbridge_top_ration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeImageView
                    android:id="@+id/mbridge_top_iv"
                    android:layout_width="match_parent"
                    android:layout_height="150dip"
                    android:scaleType="fitXY" />

            </com.mbridge.msdk.dycreator.baseview.cusview.MBRotationView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dip"
                android:layout_alignTop="@+id/mbridge_top_ration"
                android:layout_alignBottom="@+id/mbridge_top_ration">

                <ImageView
                    android:id="@+id/mbridge_top_play_bg"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/mbridge_icon_play_bg" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:layout_alignParentBottom="true"
                    android:src="@drawable/mbridge_bottom_media_control" />

                <ImageView
                    android:id="@+id/mbridge_top_finger_bg"
                    android:layout_width="60dp"
                    android:layout_height="75dp"
                    android:layout_alignLeft="@+id/mbridge_top_play_bg"
                    android:layout_alignTop="@+id/mbridge_top_play_bg"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="18dp"
                    android:src="@drawable/mbridge_finger_media_control" />

            </RelativeLayout>

            <TextView
                android:id="@+id/mbridge_top_title_tv"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_below="@+id/mbridge_top_ration"
                android:background="@drawable/mbridge_reward_shape_choice"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:lines="1"
                android:paddingLeft="45dp"
                android:textColor="@color/mbridge_white"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <com.mbridge.msdk.videocommon.view.RoundImageView
                android:id="@+id/mbridge_top_icon_iv"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_below="@id/mbridge_top_ration"
                android:layout_margin="5dp"
                android:scaleType="centerCrop" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/mbridge_bottom_item_rl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:layout_weight="1">

            <com.mbridge.msdk.dycreator.baseview.cusview.MBRotationView
                android:id="@+id/mbridge_bottom_ration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeImageView
                    android:id="@+id/mbridge_bottom_iv"
                    android:layout_width="match_parent"
                    android:layout_height="150dip"
                    android:scaleType="fitXY" />

            </com.mbridge.msdk.dycreator.baseview.cusview.MBRotationView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dip"
                android:layout_alignTop="@+id/mbridge_bottom_ration"
                android:layout_alignBottom="@+id/mbridge_bottom_ration"

                >

                <ImageView
                    android:id="@+id/mbridge_bottom_play_bg"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/mbridge_icon_play_bg" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:layout_alignParentBottom="true"
                    android:src="@drawable/mbridge_bottom_media_control" />

                <ImageView
                    android:id="@+id/mbridge_bottom_finger_bg"
                    android:layout_width="60dp"
                    android:layout_height="75dp"
                    android:layout_alignLeft="@+id/mbridge_bottom_play_bg"
                    android:layout_alignTop="@+id/mbridge_bottom_play_bg"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="18dp"
                    android:src="@drawable/mbridge_finger_media_control" />
            </RelativeLayout>

            <TextView
                android:id="@+id/mbridge_bottom_title_tv"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_below="@+id/mbridge_bottom_ration"
                android:background="@drawable/mbridge_reward_shape_choice"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:lines="1"
                android:paddingLeft="45dp"
                android:textColor="@color/mbridge_white"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <com.mbridge.msdk.videocommon.view.RoundImageView
                android:id="@+id/mbridge_bottom_icon_iv"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_below="@id/mbridge_bottom_ration"
                android:layout_margin="5dp"
                android:scaleType="centerCrop" />
        </RelativeLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/mbridge_choice_one_countdown_tv"
        android:layout_width="wrap_content"
        android:layout_height="25dp"
        android:layout_gravity="right"
        android:layout_margin="10dp"
        android:gravity="center"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:textSize="11sp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/mbridge_reward_choice_one_like_iv"
        android:layout_width="350dp"
        android:layout_height="55dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:src="@drawable/mbridge_reward_two_title_zh" />

    <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeDyImageView
        android:id="@+id/mbridge_iv_link"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/mbridge_reward_notice" />

</com.mbridge.msdk.dycreator.baseview.cusview.MBridgeFramLayout>