<?xml version="1.0" encoding="utf-8"?>
<com.mbridge.msdk.dycreator.baseview.cusview.MBridgeFramLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mbridge_ee_grey"
    >

    <RelativeLayout
        android:id="@+id/mbridge_native_ec_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/mbridge_reward_end_card_shape_bg"
        android:layout_margin="15dp"
        >
        <TextView
            android:id="@+id/mbridge_tv_apptitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:gravity="center_horizontal"
            android:textColor="@color/mbridge_black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_centerHorizontal="true"
            android:scaleType="centerCrop"
            />
        <com.mbridge.msdk.video.dynview.widget.MBridgeLevelLayoutView
            android:id="@+id/mbridge_sv_starlevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/mbridge_tv_apptitle"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            />
        <com.mbridge.msdk.videocommon.view.RoundImageView
            android:id="@+id/mbridge_iv_adbanner"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:layout_marginRight="1dp"
            android:layout_marginLeft="1dp"
            android:layout_below="@+id/mbridge_iv_icon"
            android:layout_marginTop="-35dp"
            />
        <ImageView
            android:id="@+id/mbridge_iv_icon"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:radius="10dp"
            android:layout_centerHorizontal="true"
            android:scaleType="centerCrop"
            android:layout_marginTop="20dp"
            android:layout_below="@+id/mbridge_sv_starlevel"
            />
        <TextView
            android:id="@+id/mbridge_tv_flag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:text="AD"
            android:gravity="center"
            android:visibility="gone"
            android:textSize="11dp"
            android:paddingLeft="3dp"
            android:paddingRight="3dp"
            />

        <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeDyImageView
            android:id="@+id/mbridge_iv_flag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true" />

        <TextView
            android:id="@+id/mbridge_tv_appdesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/mbridge_iv_adbanner"
            android:layout_margin="15dp"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            />

        <TextView
            android:id="@+id/mbridge_tv_cta"
            android:layout_width="270dip"
            android:layout_height="50dp"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:ellipsize="end"
            android:lines="1"
            android:layout_below="@+id/mbridge_tv_appdesc"
            />
        <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeDyImageView
            android:id="@+id/mbridge_iv_logo"
            android:layout_width="50dp"
            android:layout_height="18dp"
            android:layout_centerHorizontal="true"
            android:layout_below="@+id/mbridge_tv_cta"
            android:layout_margin="10dp"
            android:src="@drawable/mbridge_reward_end_pager_logo" />
        <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeBaitClickView
            android:id="@+id/mbridge_animation_click_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeDyImageView
            android:id="@+id/mbridge_iv_link"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/mbridge_reward_notice" />

        <com.mbridge.msdk.widget.FeedBackButton
            android:id="@+id/mbridge_native_endcard_feed_btn"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:layout_alignTop="@+id/mbridge_iv_link"
            android:layout_toEndOf="@+id/mbridge_iv_link"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="@string/mbridge_cm_feedback_btn_text"
            android:textColor="@color/mbridge_white"
            android:textSize="11sp"
            android:visibility="gone" />

        <com.mbridge.msdk.dycreator.baseview.cusview.MBridgeDyImageView
            android:id="@+id/mbridge_iv_close"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_alignParentRight="true"
            android:contentDescription="closeButton"
            android:src="@drawable/mbridge_reward_close" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/mbridge_native_ec_layer_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</com.mbridge.msdk.dycreator.baseview.cusview.MBridgeFramLayout>