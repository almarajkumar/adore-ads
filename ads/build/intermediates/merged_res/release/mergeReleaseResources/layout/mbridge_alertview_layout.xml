<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="@dimen/mbridge_video_common_alertview_bg_padding"
    android:background="@drawable/mbridge_cm_alertview_bg"
    android:padding="@dimen/mbridge_video_common_alertview_bg_padding">

    <TextView
        android:id="@+id/mbridge_alertview_titleview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        tools:text="确认关闭？"
        android:textColor="@color/mbridge_video_common_alertview_title_textcolor"
        android:textSize="@dimen/mbridge_video_common_alertview_title_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mbridge_alertview_contentview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/mbridge_alertview_titleview"
        android:layout_marginTop="@dimen/mbridge_video_common_alertview_content_margintop"
        tools:text="关闭后您将不会获得任何奖励噢~ "
        android:textColor="@color/mbridge_video_common_alertview_content_textcolor"
        android:textSize="@dimen/mbridge_video_common_alertview_content_size" />

    <Button
        android:id="@+id/mbridge_alertview_close_button"
        android:layout_width="@dimen/mbridge_video_common_alertview_button_width"
        android:layout_height="@dimen/mbridge_video_common_alertview_button_height"
        android:layout_below="@+id/mbridge_alertview_contentview"
        android:layout_marginTop="@dimen/mbridge_video_common_alertview_button_margintop"
        android:layout_marginBottom="4dp"
        android:background="@drawable/mbridge_cm_alertview_confirm_bg"
        android:gravity="center"
        tools:text="确认关闭"
        android:textColor="@color/mbridge_video_common_alertview_confirm_button_textcolor"
        android:textSize="@dimen/mbridge_video_common_alertview_button_textsize" />

    <Button
        android:id="@+id/mbridge_alertview_continue_button"
        android:layout_width="@dimen/mbridge_video_common_alertview_button_width"
        android:layout_height="@dimen/mbridge_video_common_alertview_button_height"
        android:layout_below="@+id/mbridge_alertview_contentview"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="@dimen/mbridge_video_common_alertview_button_margintop"
        android:layout_marginBottom="4dp"
        android:background="@drawable/mbridge_cm_alertview_cancel_bg"
        android:gravity="center"
        tools:text="继续观看"
        android:textColor="@color/mbridge_video_common_alertview_cancel_button_textcolor"
        android:textSize="@dimen/mbridge_video_common_alertview_button_textsize" />

</RelativeLayout>
